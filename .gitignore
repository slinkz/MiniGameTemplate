# ===== Unity =====
UnityProj/[Ll]ibrary/
UnityProj/[Tt]emp/
UnityProj/[Oo]bj/
UnityProj/[Bb]uild/
UnityProj/[Bb]uilds/
UnityProj/[Ll]ogs/
UnityProj/[Uu]ser[Ss]ettings/

# ProjectSettings — MUST be tracked for template portability
# Only ignore machine-specific files inside it
UnityProj/ProjectSettings/Packages/

# ===== Memory & IDE =====
.workbuddy/
MemoryCaptures/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Gradle =====
*.apk
*.aab
*.unitypackage
*.gz

# ===== Crashlytics =====
crashlytics-build.properties
sysinfo.txt

# ===== YooAsset =====
UnityProj/Assets/[Ss]treamingAssets/yoo/

# ===== UPM Lock (Unity auto-generated, machine-specific) =====
UnityProj/Packages/packages-lock.json
UnityProj/Packages/ResolvedPackageCache

# ===== Visual Studio workload hint (auto-generated) =====
UnityProj/.vsconfig

# ===== YooAsset build output =====
UnityProj/Bundles/

# ===== FairyGUI SDK (Junction → ThirdParty/FairyGUI-unity/Assets, do not track) =====
UnityProj/Assets/FairyGUI/
UnityProj/Assets/FairyGUI.meta

# ===== FairyGUI UIProject output (generated, tracked in Unity) =====
# UIProject 导出的 bytes/texture 在 UnityProj 中由 Unity 管理

# ===== Luban Generated (keep tracked, but ignore temp) =====
UnityProj/Tools/Luban/.cache/
